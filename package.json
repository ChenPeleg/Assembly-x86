{
  "name": "Assembly-x86",
  "version": "1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:dev": "ng build --configuration development",
    "build:pages": "ng build --configuration pages",
    "build:site": "cross-env REACT_APP_ENV=prod-firebase react-scripts build",
    "postbuild:site": "mkdir temp && mkdir temp/Sidur && cp -rf build/* temp/Sidur && cp -rf temp/* build && rm -rf temp/Sidur",
    "predeploy": "ng build --configuration pages",
    "deploy": "gh-pages -d build",
    "prebuild": "node script/listAllDocAssestFiles.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --no-watch --no-progress --browsers ChromeHeadlessCI"
  },
  "engines": {
    "node": "24"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.18",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/router": "^20.3.18",
    "@tailwindcss/postcss": "^4.2.1",
    "codemirror": "^6.0.1",
    "pegjs-loader": "^0.5.6",
    "postcss": "^8.5.8",
    "rxjs": "~7.5.0",
    "tailwindcss": "^4.2.1",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^20.0.0",
    "@angular/build": "^20.3.20",
    "@angular/cli": "~20.3.20",
    "@angular/compiler-cli": "^20.3.18",
    "@types/jasmine": "~4.0.0",
    "@types/lodash": "^4.14.188",
    "brace": "^0.8.0",
    "cross-env": "^7.0.3",
    "gh-pages": "^5.0.0",
    "jasmine-core": "~4.3.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "pegjs": "^0.10.0",
    "prettier": "^2.8.4",
    "typescript": "~5.8.3"
  }
}
